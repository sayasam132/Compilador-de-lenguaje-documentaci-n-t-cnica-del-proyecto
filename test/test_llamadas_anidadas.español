func sumar([num]x, [num]y) -> [num] {
    retorna x + y;
}

func multiplicar([num]x, [num]y) -> [num] {
    retorna x * y;
}

func restar([num]x, [num]y) -> [num] {
    retorna x - y;
}

let r1 as num = multiplicar(sumar(2, 3), 4);
let r2 as num = sumar(multiplicar(3, 4), 5);
let r3 as num = restar(multiplicar(10, 2), sumar(5, 5));
mostrar r1;
mostrar r2;
mostrar r3;
