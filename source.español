---
-- Tipos de dato basicos
let edad     as num    = 22;
let precio   as dec    = 9.99;
let inicial  as car    = 'K';
let saludo   as pal    = "Hola mundo";
let activo   as bool   = verdad;
let inactivo as bool   = no;
let error    as bool   = hola;

-- Expresiones aritmeticas con + y -
let suma  as num = edad + 8;
let resta as num = 100 - 55;

-- Expresiones con * y /
let producto  as num = 4 * 3;
let resultado as num = (100 - 55) * 2;
let cociente  as dec = 9.0 / 4.0;

-- Mostrar todos los valores
mostrar edad;
mostrar precio;
mostrar inicial;
mostrar saludo;
mostrar activo;
mostrar inactivo;
mostrar suma;
mostrar resta;
mostrar producto;
mostrar resultado;
mostrar cociente;
mostrar error;
---

let x as num = 1;
{
    let x as num = 42;
    {
        let x as num = 99;
        mostrar x;        -- imprime 99
    }
    mostrar x;            -- imprime 42
}
mostrar x;                -- imprime 1
